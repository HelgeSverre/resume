{
  "name": "@helgesverre/resume",
  "version": "0.1.0",
  "description": "Search and resume local coding-agent sessions across many tools from one searchable TUI.",
  "keywords": [
    "cli",
    "tui",
    "resume",
    "session",
    "agents"
  ],
  "homepage": "https://github.com/HelgeSverre/resume#readme",
  "bugs": "https://github.com/HelgeSverre/resume/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HelgeSverre/resume.git"
  },
  "license": "MIT",
  "author": "Helge Sverre <helge.sverre@gmail.com>",
  "type": "module",
  "bin": {
    "resume": "./dist/resume.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rescript",
    "clean": "rescript clean",
    "bundle": "esbuild lib/es6/src/Main.mjs --bundle --platform=node --format=esm --target=node22 --external:clipboardy --outfile=dist/resume.mjs --banner:js='#!/usr/bin/env node' && chmod +x dist/resume.mjs",
    "dist": "npm run clean &&  npm run build && npm run bundle",
    "prepare": "npm run dist",
    "test": "npm run build && node --test lib/es6/test/*.mjs",
    "start": "node dist/resume.mjs",
    "format": "rescript format --verbose"
  },
  "dependencies": {
    "clipboardy": "^5.3.1"
  },
  "devDependencies": {
    "@rescript/core": "^1.6.1",
    "@rescript/language-server": "^1.72.0",
    "@rescript/runtime": "^12.3.0",
    "esbuild": "^0.28.0",
    "rescript": "^12.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
